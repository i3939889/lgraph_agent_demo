# LGraph Agent Environment Configuration
# ====================================

# Google Gemini API Key (Required for Embedding)
GEMINI_API_KEY="your_google_api_key_here"

# LLM Provider Selection
# Options: "nvidia" (default), "vllm"
LLM_PROVIDER="nvidia"

# --- NVIDIA NIM Configuration ---
NVIDIA_API_KEY="your_nvidia_api_key_here"
NVIDIA_MODEL="meta/llama-3.1-8b-instruct"

# --- Local vLLM Configuration (If LLM_PROVIDER="vllm") ---
VLLM_API_BASE="http://localhost:8000/v1"
VLLM_API_KEY="empty"
VLLM_MODEL="gemma-4b"